# Project
COMPOSE_PROJECT_NAME=virtual-process
ENVIRONMENT=development
LOG_LEVEL=info

# Service ports
CHATBOT_BACKEND_PORT=8000
CONTROL_SERVER_PORT=8010
IOT_PLATFORM_PORT=8020
TELEMETRY_HTTP_PORT=8030
TELEMETRY_UDP_PORT=9999
TELEMETRY_TCP_PORT=9998
CHAT_WEB_PORT=5199
POSTGRES_PORT=5432
TIMESCALEDB_PORT=5433
QDRANT_PORT=6333
REDIS_PORT=6379
OLLAMA_PORT=11434
OLLAMA_IMAGE_TAG=0.20.0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Shared tracing
DEFAULT_CORRELATION_ID_HEADER=x-correlation-id

# Chatbot backend
CHATBOT_BACKEND_HOST=0.0.0.0
CHATBOT_BACKEND_RELOAD=true
CONTROL_SERVER_BASE_URL=http://control-server-demo:8010
CONTROL_SERVER_CLIENT_MODE=http
# UE5 Virtual Process (AGVSimController HTTP server). Set UE5_CLIENT_MODE=ue5 to drive
# the real UE5 cell; leave as mock to use the in-memory command/telemetry stub.
UE5_BASE_URL=http://host.docker.internal:7777
UE5_CLIENT_MODE=mock
UE5_VIEW_URL=http://localhost:8880
AGV_API_KEY=dev-agv-key
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_CTX=2048
OLLAMA_PLAN_NUM_PREDICT=192
OLLAMA_TOOL_NUM_PREDICT=128
OLLAMA_REPORT_NUM_PREDICT=192
SESSION_HISTORY_LIMIT=40
SESSION_HISTORY_MESSAGE_MAX_CHARS=1200
SESSION_PREVIEW_MAX_CHARS=80
DATABASE_URL=postgresql://pai:pai@postgres:5432/pai_chatbot
TIMESERIES_DATABASE_URL=postgresql://pai:pai@timescaledb:5432/pai_timeseries
QDRANT_URL=http://qdrant:6333
# Qdrant Managed Cloud: set the HTTPS cluster URL above and its database key below.
# Optional fallback retries local Qdrant without forwarding the cloud key.
QDRANT_API_KEY=
QDRANT_FALLBACK_URL=
# RAG (PA) — retrieval grounding. RAG_ENABLED toggles the KnowledgeGateway in the backend.
RAG_ENABLED=false
RAG_COLLECTION=vcore_operations_ko
RAG_EMBED_MODEL=bge-m3
RAG_TOP_K=5
RAG_FETCH_K=10
RAG_RERANK_MODE=lexical
RAG_MIN_SCORE=0.0
# Optional LLM reranker (RAG_RERANK_MODE=llm). Defaults can point to llama.cpp or any
# OpenAI-compatible chat endpoint; lexical rerank is used if the LLM call fails.
RAG_RERANK_BASE_URL=
RAG_RERANK_MODEL=
# GraphRAG (PB) wraps the vector retriever for relational station/zone/capability/KPI questions.
GRAPH_RAG_ENABLED=true
# Embeddings use the OpenAI-compatible /v1/embeddings endpoint. Kept on Ollama (engine split:
# LLM on llama.cpp, embeddings on Ollama). Defaults to the Ollama base URL when unset.
EMBED_BASE_URL=http://ollama:11434
REDIS_URL=redis://redis:6379/0
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5180,http://127.0.0.1:5180,http://localhost:5199,http://127.0.0.1:5199

# Demo data stores
POSTGRES_DB=pai_chatbot
POSTGRES_USER=pai
POSTGRES_PASSWORD=pai
TIMESCALEDB_DB=pai_timeseries
TIMESCALEDB_USER=pai
TIMESCALEDB_PASSWORD=pai

# Robot command safeguards
ROBOT_COMMAND_TIMEOUT_SECONDS=30
ROBOT_COMMAND_RETRY_COUNT=2
ROBOT_COMMAND_IDEMPOTENCY_TTL_SECONDS=300

# Remote access via ngrok (docker compose --profile remote up --build)
# 1. Get your auth token: https://dashboard.ngrok.com/get-started/your-authtoken
# 2. (Optional) Claim a free static domain: https://dashboard.ngrok.com/cloud-edge/domains
# 3. Set the three vars below and leave CHAT_WEB_API_BASE_URL/WS empty.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
NGROK_DASHBOARD_PORT=4040
# Leave these EMPTY for ngrok mode so the frontend auto-detects the backend via nginx proxy.
# For local-only mode: set to http://localhost:8000 and ws://localhost:8000.
CHAT_WEB_API_BASE_URL=
CHAT_WEB_WS_BASE_URL=
# Allow all origins when accessed through ngrok (no credentials are sent, so this is safe).
CORS_ALLOW_ORIGINS=*

# Real-time AGV telemetry → Firebase Realtime Database
# Shared logical cell id (must match UE5 [AGVSim] CellId and the dashboard).
CELL_ID=cell_demo
FIREBASE_CELL_ROOT=cells
# telemetry-collector: server-side write credentials (firebase-admin).
# Put the service-account JSON at web/secrets/firebase-sa.json (git-ignored).
FIREBASE_DB_URL=
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-sa.json
# chat-web: Firebase web SDK config (build-time, inlined by Vite). Leave the
# database URL empty to fall back to the SSE/overlay telemetry path.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
