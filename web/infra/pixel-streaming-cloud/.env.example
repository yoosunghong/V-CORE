# Public IPv4 address of the cloud VM. The three Cloudflare DNS records below
# must resolve directly to this address with Proxy status = DNS only.
PUBLIC_IP=34.50.42.22

PLAYER_DOMAIN=stream.v-core.yoosung.dev
STREAMER_DOMAIN=streamer.v-core.yoosung.dev
TURN_DOMAIN=turn.v-core.yoosung.dev
TURN_REALM=v-core.yoosung.dev
ACME_EMAIL=admin@yoosung.dev

# Replace both values. Use a long random password and keep the resulting .env
# only on the cloud VM.
TURN_USER=vcore
TURN_PASSWORD=replace-with-a-long-random-secret

STUN_SERVER=stun.l.google.com:19302
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
MAX_PLAYERS=4
